<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpToDate Admin Panel</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
      background: #f5f5f5;
      min-height: 100vh;
      padding: 40px 20px;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
    }

    .header {
      background: white;
      padding: 30px;
      border-radius: 12px;
      margin-bottom: 30px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .header h1 {
      color: #000;
      margin-bottom: 8px;
      font-size: 2.5em;
    }

    .header p {
      color: #666;
      font-size: 1.1em;
    }

    .nav-links {
      display: flex;
      gap: 20px;
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid #e5e5e5;
    }

    .nav-links a {
      color: #0071e3;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: #0057b8;
    }

    .admin-section {
      background: white;
      padding: 30px;
      border-radius: 12px;
      margin-bottom: 30px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .section-title {
      color: #000;
      font-size: 1.5em;
      margin-bottom: 30px;
      padding-bottom: 15px;
      border-bottom: 2px solid #f0f0f0;
    }

    .form-group {
      margin-bottom: 20px;
    }

    label {
      display: block;
      color: #000;
      font-weight: 500;
      margin-bottom: 8px;
      font-size: 0.95em;
    }

    input,
    textarea,
    select {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid #d1d1d1;
      border-radius: 8px;
      font-size: 1em;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
      transition: border-color 0.2s, box-shadow 0.2s;
      background: #fff;
    }

    input:focus,
    textarea:focus,
    select:focus {
      outline: none;
      border-color: #000;
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
    }

    textarea {
      resize: vertical;
      min-height: 100px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    button {
      background: #000;
      color: white;
      border: none;
      padding: 12px 32px;
      border-radius: 8px;
      font-size: 0.95em;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.1s ease;
    }

    button:hover {
      background: #1a1a1a;
    }

    button:active {
      transform: scale(0.98);
    }

    .btn-secondary {
      background: #f0f0f0;
      color: #000;
    }

    .btn-secondary:hover {
      background: #e0e0e0;
    }

    .btn-danger {
      background: #ff3b30;
    }

    .btn-danger:hover {
      background: #e63028;
    }

    .button-group {
      display: flex;
      gap: 12px;
      margin-top: 20px;
    }

    .message {
      padding: 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      display: none;
    }

    .message.success {
      background: #f0fdf4;
      color: #166534;
      border: 1px solid #86efac;
      display: block;
    }

    .message.error {
      background: #fee2e2;
      color: #991b1b;
      border: 1px solid #fca5a5;
      display: block;
    }

    .message.info {
      background: #dbeafe;
      color: #1e40af;
      border: 1px solid #93c5fd;
      display: block;
    }

    .table-container {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    table thead {
      background: #f9f9f9;
    }

    table th {
      padding: 12px 16px;
      text-align: left;
      color: #000;
      font-weight: 600;
      border-bottom: 2px solid #e5e5e5;
    }

    table td {
      padding: 12px 16px;
      border-bottom: 1px solid #e5e5e5;
      color: #666;
    }

    table tr:hover {
      background: #f9f9f9;
    }

    .actions {
      display: flex;
      gap: 8px;
    }

    .btn-edit,
    .btn-delete {
      padding: 6px 12px;
      font-size: 0.85em;
      border-radius: 6px;
    }

    .btn-edit {
      background: #0071e3;
      color: white;
    }

    .btn-edit:hover {
      background: #0057b8;
    }

    .btn-delete {
      background: #ff3b30;
      color: white;
    }

    .btn-delete:hover {
      background: #e63028;
    }

    .score-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.9em;
    }

    .score-badge.excellent {
      background: #d4f7d4;
      color: #166534;
    }

    .score-badge.good {
      background: #d1e9fd;
      color: #1e40af;
    }

    .score-badge.medium {
      background: #fed7aa;
      color: #92400e;
    }

    .score-badge.poor {
      background: #fecaca;
      color: #991b1b;
    }

    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5);
    }

    .modal.show {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .modal-content {
      background-color: white;
      padding: 40px;
      border-radius: 12px;
      width: 90%;
      max-width: 600px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 1px solid #e5e5e5;
    }

    .modal-header h2 {
      color: #000;
      font-size: 1.5em;
    }

    .close-btn {
      background: none;
      border: none;
      font-size: 1.5em;
      cursor: pointer;
      color: #999;
      padding: 0;
    }

    .close-btn:hover {
      color: #000;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }

    .stat-card {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 20px;
      border-radius: 12px;
      text-align: center;
    }

    .stat-card h3 {
      font-size: 2em;
      margin-bottom: 8px;
    }

    .stat-card p {
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.9em;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    .empty-state h3 {
      color: #666;
      margin-bottom: 8px;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <h1>🔐 UpToDate Admin Panel</h1>
      <p>Manage analyses, create new entries, and update existing data</p>
      <div class="nav-links">
        <a href="/">← Back to Main App</a>
        <a href="#create-section">Create Analysis</a>
        <a href="#manage-section">Manage Analyses</a>
      </div>
    </div>

    <!-- Statistics -->
    <div class="stats">
      <div class="stat-card">
        <h3 id="total-count">0</h3>
        <p>Total Analyses</p>
      </div>
      <div class="stat-card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
        <h3 id="avg-score">0</h3>
        <p>Average Score</p>
      </div>
      <div class="stat-card" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
        <h3 id="url-count">0</h3>
        <p>URL Analyses</p>
      </div>
    </div>

    <!-- Create/Edit Section -->
    <div class="admin-section" id="create-section">
      <h2 class="section-title">📝 Create / Edit Analysis</h2>
      
      <div id="create-message" class="message"></div>

      <form id="analysis-form">
        <div class="form-group">
          <label for="content-type">Content Type *</label>
          <select id="content-type" required onchange="updateContentTypeFields()">
            <option value="">Select content type</option>
            <option value="url">URL Analysis</option>
            <option value="text">Text Analysis</option>
          </select>
        </div>

        <div class="form-group" id="url-field" style="display: none;">
          <label for="url-input">Website URL *</label>
          <input type="url" id="url-input" placeholder="https://example.com" />
        </div>

        <div class="form-group" id="text-field" style="display: none;">
          <label for="text-input">Text Content *</label>
          <textarea id="text-input" placeholder="Paste your text content here..."></textarea>
        </div>

        <div class="form-group">
          <label for="score-input">Score (1-100) *</label>
          <input type="number" id="score-input" min="1" max="100" placeholder="75" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="age-score">Age Score (1-100) *</label>
            <input type="number" id="age-score" min="1" max="100" placeholder="80" required />
          </div>
          <div class="form-group">
            <label for="credibility-score">Credibility Score (1-100) *</label>
            <input type="number" id="credibility-score" min="1" max="100" placeholder="75" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="quality-score">Quality Score (1-100) *</label>
            <input type="number" id="quality-score" min="1" max="100" placeholder="70" required />
          </div>
          <div class="form-group">
            <label for="trust-score">Trust Score (1-100) *</label>
            <input type="number" id="trust-score" min="1" max="100" placeholder="75" required />
          </div>
        </div>

        <div class="form-group">
          <label for="reasoning-input">Reasoning</label>
          <textarea id="reasoning-input" placeholder="Explain the reasoning behind this score..."></textarea>
        </div>

        <div class="form-group">
          <label for="citation-input">MLA Citation</label>
          <textarea id="citation-input" placeholder="Enter the MLA citation for this content..."></textarea>
        </div>

        <div class="button-group">
          <button type="submit" id="submit-btn">Create Analysis</button>
          <button type="button" class="btn-secondary" id="reset-btn" onclick="resetForm()">Clear Form</button>
        </div>
      </form>

      <input type="hidden" id="edit-id" />
    </div>

    <!-- Manage Section -->
    <div class="admin-section" id="manage-section">
      <h2 class="section-title">📊 Manage Analyses</h2>

      <div id="manage-message" class="message"></div>

      <div class="table-container">
        <table id="analyses-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>URL/Content</th>
              <th>Score</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="table-body">
            <tr>
              <td colspan="5" class="empty-state">
                <h3>No analyses found</h3>
                <p>Create your first analysis using the form above</p>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    // Initialize
    document.addEventListener("DOMContentLoaded", () => {
      loadAnalyses();
      loadStats();
      document.getElementById("analysis-form").addEventListener("submit", handleFormSubmit);
    });

    function updateContentTypeFields() {
      const contentType = document.getElementById("content-type").value;
      document.getElementById("url-field").style.display = contentType === "url" ? "block" : "none";
      document.getElementById("text-field").style.display = contentType === "text" ? "block" : "none";
    }

    async function handleFormSubmit(e) {
      e.preventDefault();

      const contentType = document.getElementById("content-type").value;
      const score = parseInt(document.getElementById("score-input").value);
      const editId = document.getElementById("edit-id").value;

      if (!contentType) {
        showMessage("create-message", "Please select a content type", "error");
        return;
      }

      // Validate score
      if (score < 1 || score > 100) {
        showMessage("create-message", "Score must be between 1 and 100", "error");
        return;
      }

      const data = {
        contentType,
        score,
        breakdown: {
          ageScore: parseInt(document.getElementById("age-score").value),
          credibilityScore: parseInt(document.getElementById("credibility-score").value),
          contentQualityScore: parseInt(document.getElementById("quality-score").value),
          sourceTrustScore: parseInt(document.getElementById("trust-score").value),
        },
        reasoning: document.getElementById("reasoning-input").value,
        pageCitation: document.getElementById("citation-input").value,
      };

      if (contentType === "url") {
        const url = document.getElementById("url-input").value;
        if (!url) {
          showMessage("create-message", "Please enter a URL", "error");
          return;
        }
        data.url = url;
      } else {
        const text = document.getElementById("text-input").value;
        if (!text) {
          showMessage("create-message", "Please enter text content", "error");
          return;
        }
        data.content = text;
      }

      try {
        const method = editId ? "PUT" : "POST";
        const endpoint = editId ? `/api/analysis/${editId}` : "/api/analysis";

        const response = await fetch(endpoint, {
          method,
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const errorData = await response.json();
          throw new Error(errorData.error || "Failed to save analysis");
        }

        const successMsg = editId ? "Analysis updated successfully!" : "Analysis created successfully!";
        showMessage("create-message", "✅ " + successMsg, "success");
        resetForm();
        loadAnalyses();
        loadStats();
      } catch (err) {
        showMessage("create-message", "❌ Error: " + err.message, "error");
      }
    }

    async function loadAnalyses() {
      try {
        const response = await fetch("/api/history");
        const analyses = await response.json();

        const tableBody = document.getElementById("table-body");

        if (analyses.length === 0) {
          tableBody.innerHTML = `
            <tr>
              <td colspan="5" class="empty-state">
                <h3>No analyses found</h3>
                <p>Create your first analysis using the form above</p>
              </td>
            </tr>
          `;
          return;
        }

        tableBody.innerHTML = analyses
          .map(
            (item) => `
          <tr>
            <td>
              <span style="text-transform: capitalize; font-weight: 500;">
                ${item.contentType}
              </span>
            </td>
            <td>
              <small>${item.url?.substring(0, 50) || item.content?.substring(0, 50) || "N/A"}${
              (item.url?.length || item.content?.length || 0) > 50 ? "..." : ""
            }</small>
            </td>
            <td>
              <span class="score-badge ${getScoreClass(item.score)}">${item.score}</span>
            </td>
            <td>
              <small>${new Date(item.createdAt).toLocaleDateString()}</small>
            </td>
            <td>
              <div class="actions">
                <button class="btn-edit" onclick="editAnalysis('${item._id}')">Edit</button>
                <button class="btn-delete" onclick="deleteAnalysis('${item._id}')">Delete</button>
              </div>
            </td>
          </tr>
        `
          )
          .join("");
      } catch (err) {
        showMessage("manage-message", "❌ Failed to load analyses", "error");
      }
    }

    async function editAnalysis(id) {
      try {
        const response = await fetch(`/api/analysis/${id}`);
        if (!response.ok) throw new Error("Failed to load analysis");

        const data = await response.json();

        // Populate form
        document.getElementById("content-type").value = data.contentType;
        updateContentTypeFields();

        if (data.contentType === "url") {
          document.getElementById("url-input").value = data.url || "";
        } else {
          document.getElementById("text-input").value = data.content || "";
        }

        document.getElementById("score-input").value = data.score || "";
        document.getElementById("age-score").value = data.breakdown?.ageScore || "";
        document.getElementById("credibility-score").value = data.breakdown?.credibilityScore || "";
        document.getElementById("quality-score").value = data.breakdown?.contentQualityScore || "";
        document.getElementById("trust-score").value = data.breakdown?.sourceTrustScore || "";
        document.getElementById("reasoning-input").value = data.reasoning || "";
        document.getElementById("citation-input").value = data.pageCitation || "";
        document.getElementById("edit-id").value = id;

        // Update button text
        document.getElementById("submit-btn").textContent = "Update Analysis";

        // Scroll to form
        document.getElementById("create-section").scrollIntoView({ behavior: "smooth" });
      } catch (err) {
        showMessage("manage-message", "❌ Error: " + err.message, "error");
      }
    }

    async function deleteAnalysis(id) {
      if (!confirm("Are you sure you want to delete this analysis?")) return;

      try {
        const response = await fetch(`/api/analysis/${id}`, {
          method: "DELETE",
        });

        if (!response.ok) throw new Error("Failed to delete analysis");

        showMessage("manage-message", "✅ Analysis deleted successfully!", "success");
        loadAnalyses();
        loadStats();
      } catch (err) {
        showMessage("manage-message", "❌ Error: " + err.message, "error");
      }
    }

    async function loadStats() {
      try {
        const response = await fetch("/api/history");
        const analyses = await response.json();

        if (analyses.length === 0) {
          document.getElementById("total-count").textContent = "0";
          document.getElementById("avg-score").textContent = "0";
          document.getElementById("url-count").textContent = "0";
          return;
        }

        const totalCount = analyses.length;
        const avgScore = Math.round(
          analyses.reduce((sum, a) => sum + a.score, 0) / totalCount
        );
        const urlCount = analyses.filter((a) => a.contentType === "url").length;

        document.getElementById("total-count").textContent = totalCount;
        document.getElementById("avg-score").textContent = avgScore;
        document.getElementById("url-count").textContent = urlCount;
      } catch (err) {
        console.error("Failed to load stats:", err);
      }
    }

    function getScoreClass(score) {
      if (score >= 75) return "excellent";
      if (score >= 50) return "good";
      if (score >= 25) return "medium";
      return "poor";
    }

    function resetForm() {
      document.getElementById("analysis-form").reset();
      document.getElementById("edit-id").value = "";
      document.getElementById("submit-btn").textContent = "Create Analysis";
      document.getElementById("url-field").style.display = "none";
      document.getElementById("text-field").style.display = "none";
      showMessage("create-message", "", "");
    }

    function showMessage(elementId, message, type) {
      const element = document.getElementById(elementId);
      element.textContent = message;
      element.className = "message " + type;

      if (message) {
        setTimeout(() => {
          if (element.textContent === message) {
            element.textContent = "";
            element.className = "message";
          }
        }, 5000);
      }
    }
  </script>
</body>
</html>
