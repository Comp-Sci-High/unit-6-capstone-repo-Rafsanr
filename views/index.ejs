<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpToDate - Information Freshness Scorer</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
      background: #ffffff;
      min-height: 100vh;
      padding: 40px 20px;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
    }

    h1 {
      color: #000;
      margin-bottom: 8px;
      font-size: 3.5em;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .subtitle {
      color: #666;
      margin-bottom: 50px;
      font-size: 1.2em;
      font-weight: 400;
      letter-spacing: 0;
    }

    .tabs {
      display: flex;
      gap: 40px;
      margin-bottom: 50px;
      border-bottom: 1px solid #e5e5e5;
    }

    .tab-btn {
      padding: 12px 0;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1em;
      color: #888;
      border-bottom: 2px solid transparent;
      transition: color 0.2s ease;
      font-weight: 500;
    }

    .tab-btn.active {
      color: #000;
      border-bottom-color: #000;
    }

    .tab-btn:hover {
      color: #000;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .form-group {
      margin-bottom: 30px;
    }

    label {
      display: block;
      color: #000;
      font-weight: 500;
      margin-bottom: 12px;
      font-size: 0.95em;
    }

    input,
    textarea {
      width: 100%;
      padding: 12px 16px;
      border: 1px solid #d1d1d1;
      border-radius: 8px;
      font-size: 1em;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
      transition: border-color 0.2s, box-shadow 0.2s;
      background: #fff;
    }

    input:focus,
    textarea:focus {
      outline: none;
      border-color: #000;
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
    }

    textarea {
      resize: vertical;
      min-height: 140px;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", sans-serif;
    }

    button {
      background: #000;
      color: white;
      border: none;
      padding: 12px 32px;
      border-radius: 8px;
      font-size: 0.95em;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s ease, transform 0.1s ease;
    }

    button:hover {
      background: #1a1a1a;
    }

    button:active {
      transform: scale(0.98);
    }

    .loading {
      display: none;
      text-align: center;
      color: #888;
      font-weight: 500;
      padding: 30px 0;
    }

    .result {
      padding: 40px 0;
      display: none;
    }

    .result.show {
      display: block;
      animation: fadeIn 0.4s ease;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    .score-display {
      display: flex;
      align-items: flex-start;
      gap: 60px;
      margin-bottom: 60px;
      padding-bottom: 40px;
      border-bottom: 1px solid #f0f0f0;
    }

    .score-circle {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3.5em;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
    }

    .score-circle.excellent {
      background: #34c759;
    }

    .score-circle.good {
      background: #0a84ff;
    }

    .score-circle.medium {
      background: #ff9500;
    }

    .score-circle.poor {
      background: #ff3b30;
    }

    .score-info h3 {
      color: #000;
      margin-bottom: 8px;
      font-size: 1.4em;
      font-weight: 600;
    }

    .score-info p {
      color: #666;
      line-height: 1.6;
      font-size: 0.95em;
    }

    .breakdown {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      margin-bottom: 50px;
    }

    .breakdown-item {
      padding: 0;
    }

    .breakdown-item h4 {
      color: #000;
      margin-bottom: 16px;
      font-size: 0.95em;
      font-weight: 600;
    }

    .score-bar {
      width: 100%;
      height: 6px;
      background: #f0f0f0;
      border-radius: 3px;
      overflow: hidden;
    }

    .score-bar-fill {
      height: 100%;
      background: #000;
      border-radius: 3px;
      transition: width 0.6s ease;
    }

    .breakdown-item p {
      margin-top: 12px;
      color: #888;
      font-size: 0.85em;
    }

    .factors {
      margin-bottom: 50px;
    }

    .factors h4 {
      color: #000;
      margin-bottom: 20px;
      font-size: 1.1em;
      font-weight: 600;
    }

    .factor-item {
      background: #f5f5f5;
      padding: 16px;
      border-radius: 8px;
      margin-bottom: 12px;
      color: #333;
      font-size: 0.95em;
      line-height: 1.5;
    }

    .factor-item.positive {
      background: #f0fdf4;
      color: #166534;
    }

    .factor-item.warning {
      background: #fffbeb;
      color: #92400e;
    }

    .error-message {
      background: #fee2e2;
      color: #991b1b;
      padding: 16px;
      border-radius: 8px;
      display: none;
      margin-top: 30px;
      font-size: 0.95em;
    }

    .error-message.show {
      display: block;
    }

    .history {
      margin-top: 40px;
      padding-top: 40px;
      border-top: 1px solid #e5e5e5;
    }

    .history h3 {
      color: #000;
      margin-bottom: 30px;
      font-size: 1.3em;
      font-weight: 600;
    }

    .history-item {
      background: #f9f9f9;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 12px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      transition: all 0.2s ease;
      border: 1px solid #f0f0f0;
    }

    .history-item:hover {
      background: #f5f5f5;
      transform: translateX(4px);
    }

    .history-item-text {
      flex: 1;
    }

    .history-item-text h5 {
      color: #000;
      margin-bottom: 6px;
      word-break: break-all;
      font-size: 0.95em;
      font-weight: 500;
    }

    .history-item-text p {
      color: #888;
      font-size: 0.85em;
    }

    .history-item-score {
      font-size: 1.6em;
      font-weight: 600;
      color: #000;
      min-width: 60px;
      text-align: right;
    }

    /* Citations Styling */
    .citations-section {
      background: #f9f9f9;
      padding: 30px;
      border-radius: 12px;
      margin-top: 40px;
      border: 1px solid #f0f0f0;
    }

    .citations-section h4 {
      color: #000;
      margin-bottom: 25px;
      font-size: 1.1em;
      font-weight: 600;
    }

    .citation-item {
      background: white;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 16px;
      border: 1px solid #e5e5e5;
    }

    .citation-box {
      background: #fafafa;
      padding: 16px;
      border-radius: 8px;
      margin: 16px 0 16px 0;
      border: 1px solid #e5e5e5;
    }

    .citation-text {
      color: #333;
      font-family: "Georgia", serif;
      font-size: 0.9em;
      line-height: 1.6;
      word-break: break-word;
      margin: 0;
      padding: 0;
    }

    .copy-btn {
      background: #f0f0f0;
      color: #000;
      border: none;
      padding: 8px 16px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.85em;
      font-weight: 500;
      transition: background 0.2s ease;
    }

    .copy-btn:hover {
      background: #e0e0e0;
    }

    .sources-list {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .source-item {
      background: white;
      padding: 20px;
      border-radius: 8px;
      border: 1px solid #e5e5e5;
    }

    .source-header {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
    }

    .source-number {
      background: #f0f0f0;
      color: #000;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 0.85em;
      flex-shrink: 0;
      margin-top: 2px;
    }

    .source-title {
      color: #0071e3;
      text-decoration: none;
      font-weight: 500;
      flex: 1;
      word-break: break-word;
      transition: color 0.2s ease;
      font-size: 0.95em;
    }

    .source-title:hover {
      color: #0067d8;
      text-decoration: underline;
    }

    .citation-box {
      margin-left: 0;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>📰 UpToDate</h1>
    <p class="subtitle">
      Score the freshness and accuracy of any information online (1-100)
    </p>

    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('url')">
        Analysis by URL
      </button>
      <button class="tab-btn" onclick="switchTab('text')">
        Analysis by Text
      </button>
      <button class="tab-btn" onclick="switchTab('history')">
        History
      </button>
    </div>

    <!-- URL Tab -->
    <div id="url" class="tab-content active">
      <form onsubmit="analyzeURL(event)">
        <div class="form-group">
          <label for="url-input">
            Enter a Website URL or Article Link
          </label>
          <input
            type="url"
            id="url-input"
            placeholder="https://example.com/article"
            required
          />
        </div>
        <button type="submit">Analyze URL</button>
      </form>

      <div class="loading" id="url-loading">
        <p>🔍 Analyzing URL... This may take a moment.</p>
      </div>

      <div class="error-message" id="url-error"></div>

      <div class="result" id="url-result"></div>
    </div>

    <!-- Text Tab -->
    <div id="text" class="tab-content">
      <form onsubmit="analyzeText(event)">
        <div class="form-group">
          <label for="text-input">Paste your text content here</label>
          <textarea
            id="text-input"
            placeholder="Paste the text you want to analyze..."
            required
          ></textarea>
        </div>
        <button type="submit">Analyze Text</button>
      </form>

      <div class="loading" id="text-loading">
        <p>🔍 Analyzing text...</p>
      </div>

      <div class="error-message" id="text-error"></div>

      <div class="result" id="text-result"></div>
    </div>

    <!-- History Tab -->
    <div id="history" class="tab-content">
      <div class="history">
        <h3>Recent Analyses</h3>
        <div id="history-list"></div>
      </div>
    </div>
  </div>

  <script>
    function switchTab(tabName) {
      // Hide all tabs
      document.querySelectorAll(".tab-content").forEach((tab) => {
        tab.classList.remove("active");
      });
      document.querySelectorAll(".tab-btn").forEach((btn) => {
        btn.classList.remove("active");
      });

      // Show selected tab
      document.getElementById(tabName).classList.add("active");
      event.target.classList.add("active");

      if (tabName === "history") {
        loadHistory();
      }
    }

    async function analyzeURL(e) {
      e.preventDefault();
      const url = document.getElementById("url-input").value;
      const loading = document.getElementById("url-loading");
      const error = document.getElementById("url-error");
      const result = document.getElementById("url-result");

      error.classList.remove("show");
      result.classList.remove("show");
      loading.style.display = "block";

      try {
        const response = await fetch("/api/analyze-url", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url }),
        });

        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.error || "Failed to analyze URL");
        }

        const data = await response.json();
        displayResult(data, "url-result");
      } catch (err) {
        error.textContent = "❌ Error: " + err.message;
        error.classList.add("show");
      } finally {
        loading.style.display = "none";
      }
    }

    async function analyzeText(e) {
      e.preventDefault();
      const text = document.getElementById("text-input").value;
      const loading = document.getElementById("text-loading");
      const error = document.getElementById("text-error");
      const result = document.getElementById("text-result");

      error.classList.remove("show");
      result.classList.remove("show");
      loading.style.display = "block";

      try {
        const response = await fetch("/api/analyze-text", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ text }),
        });

        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.error || "Failed to analyze text");
        }

        const data = await response.json();
        displayResult(data, "text-result");
      } catch (err) {
        error.textContent = "❌ Error: " + err.message;
        error.classList.add("show");
      } finally {
        loading.style.display = "none";
      }
    }

    function displayResult(data, resultId) {
      const score = data.score;
      const scoreClass =
        score >= 75 ? "excellent" : score >= 50 ? "good" : score >= 25 ? "medium" : "poor";
      const scoreLabel =
        score >= 75 ? "Excellent" : score >= 50 ? "Good" : score >= 25 ? "Fair" : "Poor";

      let html = `
        <div class="score-display">
          <div class="score-circle ${scoreClass}">${score}</div>
          <div class="score-info">
            <h3>Overall Score: ${scoreLabel}</h3>
            <p>${data.reasoning || "Analysis complete"}</p>
          </div>
        </div>

        <div class="breakdown">
          <div class="breakdown-item">
            <h4>Age Score</h4>
            <div class="score-bar">
              <div class="score-bar-fill" style="width: ${data.breakdown.ageScore}%"></div>
            </div>
            <p style="margin-top: 8px; color: #666; font-size: 0.9em;">${data.breakdown.ageScore}/100</p>
          </div>
          <div class="breakdown-item">
            <h4>Credibility Score</h4>
            <div class="score-bar">
              <div class="score-bar-fill" style="width: ${data.breakdown.credibilityScore}%"></div>
            </div>
            <p style="margin-top: 8px; color: #666; font-size: 0.9em;">${data.breakdown.credibilityScore}/100</p>
          </div>
          <div class="breakdown-item">
            <h4>Quality Score</h4>
            <div class="score-bar">
              <div class="score-bar-fill" style="width: ${data.breakdown.contentQualityScore}%"></div>
            </div>
            <p style="margin-top: 8px; color: #666; font-size: 0.9em;">${data.breakdown.contentQualityScore}/100</p>
          </div>
          <div class="breakdown-item">
            <h4>Trust Score</h4>
            <div class="score-bar">
              <div class="score-bar-fill" style="width: ${data.breakdown.sourceTrustScore}%"></div>
            </div>
            <p style="margin-top: 8px; color: #666; font-size: 0.9em;">${data.breakdown.sourceTrustScore}/100</p>
          </div>
        </div>

        <div class="factors">
          <h4>📊 Key Factors</h4>
          ${data.factors
            .map((factor) => {
              const isPositive = factor.includes("✅");
              return `<div class="factor-item ${isPositive ? "positive" : "warning"}">${factor}</div>`;
            })
            .join("")}
        </div>

        ${data.pageCitation ? `
        <div class="citations-section">
          <h4>📚 MLA Citation</h4>
          <div class="citation-item">
            <p class="citation-text">${escapeHtml(data.pageCitation)}</p>
            <button class="copy-btn" data-citation="${escapeHtml(data.pageCitation)}" onclick="copyCitation(this)">Copy Citation</button>
          </div>
        </div>
        ` : ""}

        ${data.citations && data.citations.length > 0 ? `
        <div class="citations-section">
          <h4>🔗 Referenced Sources (${data.citations.length})</h4>
          <div class="sources-list">
            ${data.citations
              .slice(0, 10)
              .map(
                (source, idx) => `
              <div class="source-item">
                <div class="source-header">
                  <span class="source-number">${idx + 1}.</span>
                  <a href="${source.url}" target="_blank" title="${source.title}" class="source-title">
                    ${source.title.substring(0, 80)}${source.title.length > 80 ? "..." : ""}
                  </a>
                </div>
                <div class="citation-box">
                  <p class="citation-text">${escapeHtml(source.citation)}</p>
                  <button class="copy-btn" data-citation="${escapeHtml(source.citation)}" onclick="copyCitation(this)">Copy</button>
                </div>
              </div>
            `
              )
              .join("")}
            ${data.citations.length > 10 ? `<p style="color: #999; font-size: 0.9em; margin-top: 10px;">... and ${data.citations.length - 10} more sources</p>` : ""}
          </div>
        </div>
        ` : ""}
      `;

      document.getElementById(resultId).innerHTML = html;
      document.getElementById(resultId).classList.add("show");
    }

    function escapeHtml(text) {
      const map = {
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#039;",
      };
      return text.replace(/[&<>"']/g, (m) => map[m]);
    }

    function copyCitation(button) {
      const citation = button.getAttribute('data-citation');
      navigator.clipboard
        .writeText(citation)
        .then(() => {
          alert("Citation copied to clipboard!");
        })
        .catch(() => {
          alert("Failed to copy citation");
        });
    }

    async function loadHistory() {
      try {
        const response = await fetch("/api/history");
        const data = await response.json();

        let html = "";
        if (data.length === 0) {
          html = "<p style='color: #999;'>No analyses yet. Start by analyzing a URL or text!</p>";
        } else {
          html = data
            .map(
              (item) =>
                `<div class="history-item" onclick="loadHistoryItem('${item._id}')" style="cursor: pointer;">
              <div class="history-item-text">
                <h5>${item.url || item.content.substring(0, 50)}</h5>
                <p>${new Date(item.createdAt).toLocaleString()}</p>
              </div>
              <div class="history-item-score">${item.score}</div>
            </div>`
            )
            .join("");
        }

        document.getElementById("history-list").innerHTML = html;
      } catch (err) {
        document.getElementById("history-list").innerHTML =
          "<p style='color: red;'>Failed to load history</p>";
      }
    }

    async function loadHistoryItem(id) {
      try {
        const response = await fetch(`/api/analysis/${id}`);
        
        if (!response.ok) {
          throw new Error("Failed to load analysis");
        }

        const data = await response.json();
        
        // Switch to the appropriate tab based on content type
        if (data.contentType === "url") {
          switchTabByName("url");
          // Populate the URL input field
          document.getElementById("url-input").value = data.url;
          document.getElementById("url-result").innerHTML = "";
          displayResult(data, "url-result");
        } else {
          switchTabByName("text");
          // Populate the text input field
          document.getElementById("text-input").value = data.content;
          document.getElementById("text-result").innerHTML = "";
          displayResult(data, "text-result");
        }
      } catch (err) {
        alert("❌ Error: " + err.message);
      }
    }

    function switchTabByName(tabName) {
      // Hide all tabs
      document.querySelectorAll(".tab-content").forEach((tab) => {
        tab.classList.remove("active");
      });
      document.querySelectorAll(".tab-btn").forEach((btn) => {
        btn.classList.remove("active");
      });

      // Show selected tab
      document.getElementById(tabName).classList.add("active");
      document.querySelectorAll(".tab-btn").forEach((btn) => {
        if (btn.textContent.toLowerCase().includes(tabName === "url" ? "url" : tabName === "text" ? "text" : "history")) {
          btn.classList.add("active");
        }
      });
    }
  </script>
</body>
</html>
