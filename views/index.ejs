<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>UpToDate - Information Freshness Scorer</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 20px;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
      background: white;
      border-radius: 15px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      padding: 40px;
    }

    h1 {
      color: #333;
      margin-bottom: 10px;
      font-size: 2.5em;
    }

    .subtitle {
      color: #666;
      margin-bottom: 30px;
      font-size: 1.1em;
    }

    .tabs {
      display: flex;
      gap: 10px;
      margin-bottom: 30px;
      border-bottom: 2px solid #eee;
    }

    .tab-btn {
      padding: 12px 20px;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1em;
      color: #666;
      border-bottom: 3px solid transparent;
      transition: all 0.3s;
    }

    .tab-btn.active {
      color: #667eea;
      border-bottom-color: #667eea;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
    }

    .form-group {
      margin-bottom: 20px;
    }

    label {
      display: block;
      color: #333;
      font-weight: 600;
      margin-bottom: 8px;
    }

    input,
    textarea {
      width: 100%;
      padding: 12px;
      border: 2px solid #eee;
      border-radius: 8px;
      font-size: 1em;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      transition: border-color 0.3s;
    }

    input:focus,
    textarea:focus {
      outline: none;
      border-color: #667eea;
    }

    textarea {
      resize: vertical;
      min-height: 150px;
    }

    button {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      padding: 12px 30px;
      border-radius: 8px;
      font-size: 1em;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.4);
    }

    .loading {
      display: none;
      text-align: center;
      color: #667eea;
      font-weight: 600;
    }

    .result {
      background: #f8f9fa;
      padding: 25px;
      border-radius: 12px;
      margin-top: 30px;
      display: none;
    }

    .result.show {
      display: block;
      animation: slideIn 0.3s ease;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .score-display {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 25px;
      padding: 20px;
      background: white;
      border-radius: 12px;
      border-left: 5px solid #667eea;
    }

    .score-circle {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3em;
      font-weight: bold;
      color: white;
      flex-shrink: 0;
    }

    .score-circle.excellent {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .score-circle.good {
      background: linear-gradient(135deg, #56ab2f 0%, #a8e063 100%);
    }

    .score-circle.medium {
      background: linear-gradient(135deg, #f59e0b 0%, #f97316 100%);
    }

    .score-circle.poor {
      background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
    }

    .score-info h3 {
      color: #333;
      margin-bottom: 5px;
    }

    .score-info p {
      color: #666;
      margin-bottom: 8px;
    }

    .breakdown {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
      margin-bottom: 25px;
    }

    .breakdown-item {
      background: white;
      padding: 15px;
      border-radius: 8px;
      border: 1px solid #eee;
    }

    .breakdown-item h4 {
      color: #333;
      margin-bottom: 8px;
      font-size: 0.95em;
    }

    .score-bar {
      width: 100%;
      height: 8px;
      background: #eee;
      border-radius: 4px;
      overflow: hidden;
    }

    .score-bar-fill {
      height: 100%;
      background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
      border-radius: 4px;
    }

    .factors {
      margin-bottom: 25px;
    }

    .factors h4 {
      color: #333;
      margin-bottom: 12px;
    }

    .factor-item {
      background: white;
      padding: 10px 15px;
      border-radius: 6px;
      margin-bottom: 8px;
      border-left: 3px solid #667eea;
      color: #555;
    }

    .factor-item.positive {
      border-left-color: #56ab2f;
      background: #f0fdf4;
    }

    .factor-item.warning {
      border-left-color: #f59e0b;
      background: #fffbeb;
    }

    .error-message {
      background: #fee2e2;
      color: #991b1b;
      padding: 15px;
      border-radius: 8px;
      border-left: 4px solid #dc2626;
      display: none;
      margin-top: 20px;
    }

    .error-message.show {
      display: block;
    }

    .history {
      margin-top: 40px;
      padding-top: 30px;
      border-top: 2px solid #eee;
    }

    .history h3 {
      color: #333;
      margin-bottom: 15px;
    }

    .history-item {
      background: white;
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 10px;
      border: 1px solid #eee;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .history-item-text {
      flex: 1;
    }

    .history-item-text h5 {
      color: #333;
      margin-bottom: 5px;
      word-break: break-all;
    }

    .history-item-text p {
      color: #666;
      font-size: 0.9em;
    }

    .history-item-score {
      font-size: 1.5em;
      font-weight: bold;
      color: #667eea;
      min-width: 60px;
      text-align: right;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>📰 UpToDate</h1>
    <p class="subtitle">
      Score the freshness and accuracy of any information online (1-100)
    </p>

    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('url')">
        Analysis by URL
      </button>
      <button class="tab-btn" onclick="switchTab('text')">
        Analysis by Text
      </button>
      <button class="tab-btn" onclick="switchTab('history')">
        History
      </button>
    </div>

    <!-- URL Tab -->
    <div id="url" class="tab-content active">
      <form onsubmit="analyzeURL(event)">
        <div class="form-group">
          <label for="url-input">
            Enter a Website URL or Article Link
          </label>
          <input
            type="url"
            id="url-input"
            placeholder="https://example.com/article"
            required
          />
        </div>
        <button type="submit">Analyze URL</button>
      </form>

      <div class="loading" id="url-loading">
        <p>🔍 Analyzing URL... This may take a moment.</p>
      </div>

      <div class="error-message" id="url-error"></div>

      <div class="result" id="url-result"></div>
    </div>

    <!-- Text Tab -->
    <div id="text" class="tab-content">
      <form onsubmit="analyzeText(event)">
        <div class="form-group">
          <label for="text-input">Paste your text content here</label>
          <textarea
            id="text-input"
            placeholder="Paste the text you want to analyze..."
            required
          ></textarea>
        </div>
        <button type="submit">Analyze Text</button>
      </form>

      <div class="loading" id="text-loading">
        <p>🔍 Analyzing text...</p>
      </div>

      <div class="error-message" id="text-error"></div>

      <div class="result" id="text-result"></div>
    </div>

    <!-- History Tab -->
    <div id="history" class="tab-content">
      <div class="history">
        <h3>Recent Analyses</h3>
        <div id="history-list"></div>
      </div>
    </div>
  </div>

  <script>
    function switchTab(tabName) {
      // Hide all tabs
      document.querySelectorAll(".tab-content").forEach((tab) => {
        tab.classList.remove("active");
      });
      document.querySelectorAll(".tab-btn").forEach((btn) => {
        btn.classList.remove("active");
      });

      // Show selected tab
      document.getElementById(tabName).classList.add("active");
      event.target.classList.add("active");

      if (tabName === "history") {
        loadHistory();
      }
    }

    async function analyzeURL(e) {
      e.preventDefault();
      const url = document.getElementById("url-input").value;
      const loading = document.getElementById("url-loading");
      const error = document.getElementById("url-error");
      const result = document.getElementById("url-result");

      error.classList.remove("show");
      result.classList.remove("show");
      loading.style.display = "block";

      try {
        const response = await fetch("/api/analyze-url", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ url }),
        });

        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.error || "Failed to analyze URL");
        }

        const data = await response.json();
        displayResult(data, "url-result");
      } catch (err) {
        error.textContent = "❌ Error: " + err.message;
        error.classList.add("show");
      } finally {
        loading.style.display = "none";
      }
    }

    async function analyzeText(e) {
      e.preventDefault();
      const text = document.getElementById("text-input").value;
      const loading = document.getElementById("text-loading");
      const error = document.getElementById("text-error");
      const result = document.getElementById("text-result");

      error.classList.remove("show");
      result.classList.remove("show");
      loading.style.display = "block";

      try {
        const response = await fetch("/api/analyze-text", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ text }),
        });

        if (!response.ok) {
          const data = await response.json();
          throw new Error(data.error || "Failed to analyze text");
        }

        const data = await response.json();
        displayResult(data, "text-result");
      } catch (err) {
        error.textContent = "❌ Error: " + err.message;
        error.classList.add("show");
      } finally {
        loading.style.display = "none";
      }
    }

    function displayResult(data, resultId) {
      const score = data.score;
      const scoreClass =
        score >= 75 ? "excellent" : score >= 50 ? "good" : score >= 25 ? "medium" : "poor";
      const scoreLabel =
        score >= 75 ? "Excellent" : score >= 50 ? "Good" : score >= 25 ? "Fair" : "Poor";

      let html = `
        <div class="score-display">
          <div class="score-circle ${scoreClass}">${score}</div>
          <div class="score-info">
            <h3>Overall Score: ${scoreLabel}</h3>
            <p>${data.reasoning || "Analysis complete"}</p>
          </div>
        </div>

        <div class="breakdown">
          <div class="breakdown-item">
            <h4>Age Score</h4>
            <div class="score-bar">
              <div class="score-bar-fill" style="width: ${data.breakdown.ageScore}%"></div>
            </div>
            <p style="margin-top: 8px; color: #666; font-size: 0.9em;">${data.breakdown.ageScore}/100</p>
          </div>
          <div class="breakdown-item">
            <h4>Credibility Score</h4>
            <div class="score-bar">
              <div class="score-bar-fill" style="width: ${data.breakdown.credibilityScore}%"></div>
            </div>
            <p style="margin-top: 8px; color: #666; font-size: 0.9em;">${data.breakdown.credibilityScore}/100</p>
          </div>
          <div class="breakdown-item">
            <h4>Quality Score</h4>
            <div class="score-bar">
              <div class="score-bar-fill" style="width: ${data.breakdown.contentQualityScore}%"></div>
            </div>
            <p style="margin-top: 8px; color: #666; font-size: 0.9em;">${data.breakdown.contentQualityScore}/100</p>
          </div>
          <div class="breakdown-item">
            <h4>Trust Score</h4>
            <div class="score-bar">
              <div class="score-bar-fill" style="width: ${data.breakdown.sourceTrustScore}%"></div>
            </div>
            <p style="margin-top: 8px; color: #666; font-size: 0.9em;">${data.breakdown.sourceTrustScore}/100</p>
          </div>
        </div>

        <div class="factors">
          <h4>📊 Key Factors</h4>
          ${data.factors
            .map((factor) => {
              const isPositive = factor.includes("✅");
              return `<div class="factor-item ${isPositive ? "positive" : "warning"}">${factor}</div>`;
            })
            .join("")}
        </div>
      `;

      document.getElementById(resultId).innerHTML = html;
      document.getElementById(resultId).classList.add("show");
    }

    async function loadHistory() {
      try {
        const response = await fetch("/api/history");
        const data = await response.json();

        let html = "";
        if (data.length === 0) {
          html = "<p style='color: #999;'>No analyses yet. Start by analyzing a URL or text!</p>";
        } else {
          html = data
            .map(
              (item) =>
                `<div class="history-item">
              <div class="history-item-text">
                <h5>${item.url || item.content.substring(0, 50)}</h5>
                <p>${new Date(item.createdAt).toLocaleString()}</p>
              </div>
              <div class="history-item-score">${item.score}</div>
            </div>`
            )
            .join("");
        }

        document.getElementById("history-list").innerHTML = html;
      } catch (err) {
        document.getElementById("history-list").innerHTML =
          "<p style='color: red;'>Failed to load history</p>";
      }
    }
  </script>
</body>
</html>
